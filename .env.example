# ── Dcrawler Environment Configuration ─────────────────────────────────────
# Copy this file to .env and fill in your API keys.
# Only the keys for the providers you use are required.

# OpenAI (gpt-4.1, gpt-5.2, gpt-5-mini, gpt-5-nano, etc.)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (claude-sonnet-4-5, claude-sonnet-4-0)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini (gemini-2.5-flash, gemini-2.5-flash-lite, gemini-2.5-pro)
GOOGLE_API_KEY=your_google_api_key_here

# OpenRouter (access to many models via one API key)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama (local models — set base URL if not default)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# llama.cpp (OpenAI-compatible local server)
LLAMA_CPP_BASE_URL=

# ── Storage & Reporting (optional overrides) ────────────────────────────────
# Path to the SQLite database file
DCRAWLER_DB=dcrawler.db

# Path to the encryption key file (keep private, never commit)
DCRAWLER_KEY=.dcrawler.key

# Directory where HTML/text reports are saved
DCRAWLER_REPORTS=reports
